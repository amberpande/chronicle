# Chronicle Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Backend ──────────────────────────────────────────────────────
API_PORT=8000
DUCKDB_PATH=./data/chronicle.db

# ── Clerk Auth (get free keys at clerk.com) ───────────────────────
# Create an application → API Keys → copy both keys below
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Stripe Payments (get free keys at stripe.com) ────────────────
# Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── Snowflake (optional — enterprise tier only) ───────────────────
# Leave blank to use local DuckDB (recommended for dev)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
