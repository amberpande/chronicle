# Chronicle Frontend — Next.js Environment Variables
# Copy this to chronicle/frontend/.env.local
# cp .env.local.example frontend/.env.local

# Backend API URL (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Clerk Auth — get free keys at clerk.com
# Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk redirect URLs — leave these as-is for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app
